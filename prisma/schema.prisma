generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String          @id @default(uuid())
  slug          String          @unique
  name          String
  email         String          @unique
  passwordHash  String
  coreAiApiId   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  coreAiApi      CoreAiApi?      @relation(fields: [coreAiApiId], references: [id], onDelete: SetNull)
  channelConfigs ChannelConfig[]
  messages       Message[]
  contactProfiles ContactProfile[]
  contacts        Contact[]
  notifications   Notification[]
  outboundMessageJobs OutboundMessageJob[]
  whatsappGroupSettings WhatsAppGroupSetting[]

  @@index([coreAiApiId])
}

model CoreAiApi {
  id          String   @id @default(uuid())
  name        String
  baseUrl     String   @unique
  apiKey      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants     Tenant[]
}

model ChannelConfig {
  id           String   @id @default(uuid())
  tenantId     String
  channelType  String   // "whatsapp_qr", "whatsapp", "instagram", "messenger", "twilio_sms"
  
  // Platform specific credentials stored securely
  verifyToken  String?  // For webhooks validation
  accessToken  String?  // For sending messages
  phoneId      String?  // WA Phone ID, etc.
  businessAccountId String? // WhatsApp Business Account ID (WABA)
  pageId       String?  // FB Page ID
  
  provider             String?
  providerInstanceId   String?
  providerInstanceName String?
  connectionStatus     String?
  qrCode               String?  @db.Text
  qrUpdatedAt          DateTime?
  webhookSecret        String?
  voiceReplyMode       String   @default("voice") // "voice", "text", "both"
  groupReplyRule       String   @default("mention_keyword")
  groupKeywords        Json?
  providerMetadata     Json?

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelType])
}

model Message {
  id               String   @id @default(uuid())
  tenantId         String
  contactId        String?
  channelType      String   // "whatsapp_qr", "whatsapp", "instagram", "messenger", "twilio_sms"
  direction        String   // "inbound" or "outbound"
  content          String
  
  senderId         String?  // User's phone number or external ID
  receiverId       String?  // Tenant's phone number or external ID
  
  externalMessageId String? // ID from the platform
  provider          String?
  chatId            String?
  groupId           String?
  participantId     String?
  mediaType         String?
  transcript        String? @db.Text
  processingStatus  String?
  providerPayload   Json?
  
  createdAt        DateTime @default(now())
  
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  outboundJobs     OutboundMessageJob[]

  @@index([tenantId, createdAt])
  @@index([tenantId, channelType, createdAt])
  @@index([contactId])
  @@index([tenantId, externalMessageId])
  @@index([tenantId, chatId])
}

model ContactProfile {
  id          String   @id @default(uuid())
  tenantId    String
  displayName String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  notifications Notification[]

  @@index([tenantId])
}

model Contact {
  id          String   @id @default(uuid())
  tenantId    String
  profileId   String
  channelType String
  externalId  String
  displayName String?
  lastReadAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile       ContactProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages      Message[]
  notifications Notification[]
  outboundMessageJobs OutboundMessageJob[]

  @@unique([tenantId, channelType, externalId])
  @@index([tenantId, profileId])
  @@index([tenantId, channelType])
}

model Notification {
  id          String   @id @default(uuid())
  tenantId    String
  profileId   String?
  contactId   String?
  type        String
  channelType String?
  title       String
  body        String
  severity    String   @default("info")
  sourceType  String?
  sourceId    String?
  metadata    Json?
  readAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile ContactProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  contact Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([tenantId, sourceType, sourceId])
  @@index([tenantId, dismissedAt, createdAt])
  @@index([tenantId, readAt])
}

model OutboundMessageJob {
  id          String   @id @default(uuid())
  tenantId    String
  messageId   String?
  contactId   String?
  channelType String
  jobType     String
  status      String   @default("pending") // pending, processing, retry, sent, dead
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  nextRunAt   DateTime @default(now())
  lockedAt    DateTime?
  sentAt      DateTime?
  payload     Json
  lastError   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, nextRunAt])
  @@index([messageId])
}

model WhatsAppGroupSetting {
  id          String   @id @default(uuid())
  tenantId    String
  channelType String   @default("whatsapp_qr")
  groupJid    String
  groupName   String?
  isEnabled   Boolean  @default(false)
  replyRule   String   @default("mention_keyword")
  keywords    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channelType, groupJid])
  @@index([tenantId, channelType])
}
